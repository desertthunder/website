---
import "$/styles/styles.css";
import { getBuildInfo } from "$/lib/build/info";

type Props = { title: string; description?: string; currentPath?: string; showTitle?: boolean };

const { title, description = "", currentPath = "/", showTitle = true } = Astro.props;
const buildInfo = getBuildInfo();

const siteUrl = Astro.site || "https://desertthunder.dev";
const ogImageUrl = new URL("/og.png", siteUrl).toString();
const canonicalUrl = new URL(currentPath, siteUrl).toString();

const navItems = [
  { path: "/", label: "~/home", icon: "i-ri-home-4-line" },
  { path: "/blog", label: "~/blog", icon: "i-ri-article-line" },
  { path: "/projects", label: "~/projects", icon: "i-ri-tools-fill" },
  { path: "/lab", label: "~/lab", icon: "i-ri-flask-line" },
  { path: "/experience", label: "~/work", icon: "i-ri-briefcase-line" },
  { path: "/bookmarks", label: "~/bookmarks", icon: "i-ri-bookmark-line" },
  { path: "/search", label: "~/search", icon: "i-ri-search-line" },
];

const externalLinks = [
  {
    href: "https://links.desertthunder.dev",
    label: "/var/links/",
    description: "Open Owais's links directory",
    icon: "i-simple-icons-bento",
  },
  {
    href: "https://garden.desertthunder.dev",
    label: "/var/garden/",
    description: "Open Owais's digital garden",
    icon: "i-ri-cactus-line",
  },
  {
    href: "https://bsky.app/profile/desertthunder.dev",
    label: "/var/resume/",
    description: "Open Owais's BlueSky profile.",
    icon: "i-simple-icons-bluesky",
  },
];
---

<!doctype html>
<html lang="en" class="h-full p-2">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>Owais J. | {title}</title>

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={`${title}`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="Desert Thunder" />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalUrl} />
    <meta property="twitter:title" content={`${title}`} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImageUrl} />

    <link rel="canonical" href={canonicalUrl} />
  </head>
  <body class="h-full bg-terminal-bg text-terminal-text font-chrome overflow-hidden">
    <div class="h-full flex flex-col border-2 border-terminal-border rounded overflow-hidden">
      <header
        class="bg-terminal-bg-secondary border-b border-terminal-border px-3 sm:px-4 py-2 sm:py-3 flex items-center justify-between shrink-0">
        <div class="flex items-center gap-2 sm:gap-3">
          <button
            id="mobile-menu-toggle"
            class="lg:hidden flex items-center justify-center w-8 h-8 rounded hover:bg-terminal-bg-tertiary transition-colors"
            aria-label="Toggle navigation menu"
            aria-expanded="false">
            <i class="i-ri-menu-line w-5 h-5 text-terminal-text-muted"></i>
          </button>

          <div class="flex items-center gap-2">
            <span class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-terminal-error"></span>
            <span class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-terminal-warning"></span>
            <span class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-terminal-success"></span>
          </div>
          <span class="hidden sm:flex items-center">
            <i class="i-ri-terminal-box-line w-4 h-4 text-terminal-primary"></i>
          </span>
          <span class="text-terminal-text-muted text-xs sm:text-sm truncate max-w-30 sm:max-w-none">
            DESERTTHUNDER.DEV
          </span>
        </div>
        <div class="flex items-center gap-3 sm:gap-4 text-xs sm:text-sm text-terminal-text-dim">
          <a
            href="/search"
            id="header-search"
            class="flex items-center gap-1.5 hover:text-terminal-primary transition-colors"
            title="Search (/)">
            <span class="flex items-center">
              <i class="i-ri-search-line w-3.5 h-3.5 sm:w-4 sm:h-4"></i>
            </span>
            <kbd class="hidden sm:inline text-[10px] border border-terminal-border rounded px-1 py-0.5">/</kbd>
          </a>
          <span class="flex items-center gap-1.5">
            <span class="flex items-center">
              <i class="i-ri-time-line w-3.5 h-3.5 sm:w-4 sm:h-4"></i>
            </span>
            <a id="clock" href="https://time.is" target="_blank" class="terminal-link tabular-nums">--:--:--</a>
          </span>
        </div>
      </header>

      <div class="flex-1 flex overflow-hidden relative">
        <nav
          id="sidebar"
          class="absolute lg:relative z-20 w-64 lg:w-56 bg-terminal-bg-secondary border-r border-terminal-border flex flex-col shrink-0 transform -translate-x-full lg:translate-x-0 transition-transform duration-200 ease-out h-full">
          <div class="p-4 border-b border-terminal-border">
            <div class="text-terminal-text-muted text-xs mb-2">DIRECTORY</div>
            <div class="text-terminal-primary font-bold">owais/</div>
          </div>

          <div class="flex-1 overflow-y-auto py-2">
            {
              navItems.map((item) => {
                const isActive = currentPath === item.path || (item.path !== "/" && currentPath.startsWith(item.path));
                return (
                  <a
                    href={item.path}
                    class:list={[
                      "flex items-center gap-3 px-4 py-3 lg:py-2 text-sm terminal-link min-h-11",
                      isActive
                        ? "bg-terminal-primary/10 text-terminal-primary-bright border-r-2 border-terminal-primary"
                        : "text-terminal-text-muted hover:text-terminal-text",
                    ]}>
                    <span class="flex items-center shrink-0">
                      <i class:list={[item.icon, "w-4", "h-4"]} />
                    </span>
                    <span>{item.label}</span>
                  </a>
                );
              })
            }
          </div>
          <hr class="border-terminal-border" />
          <div class="flex items-center justify-between gap-2 px-4 py-3">
            {
              externalLinks.map((link) => (
                <a
                  href={link.href}
                  target="_blank"
                  title={link.label}
                  rel="noopener noreferrer"
                  class="flex items-center justify-center w-9 h-9 rounded terminal-link hover:bg-terminal-bg-tertiary"
                  aria-label={link.description}>
                  <i class:list={[link.icon, "w-5", "h-5"]} aria-hidden="true" />
                  <span class="sr-only">{link.description}</span>
                </a>
              ))
            }
          </div>

          <div class="p-4 border-t border-terminal-border text-xs text-terminal-text-dim">
            <div class="flex items-center gap-2 mb-1">
              <a
                href="https://github.com/desertthunder/website"
                class="flex items-center gap-2 hover:text-terminal-primary transition-colors"
                target="_blank"
                rel="noopener noreferrer">
                <i class="i-ri-git-branch-line w-3 h-3"></i>
                <span>{buildInfo.displayVersion}</span>
              </a>
            </div>
            <div class="flex items-center gap-2">
              <span class="flex items-center">
                <i class="i-ri-circle-fill w-2 h-2 text-terminal-success"></i>
              </span>
              <span>
                <a
                  href="https://aturi.to/profile/desertthunder.dev"
                  class="hover:text-terminal-primary transition-colors"
                  target="_blank"
                  rel="noopener noreferrer">
                  online
                </a>
                &nbsp;(always)
              </span>
            </div>
          </div>
        </nav>

        <!-- Mobile Overlay - Click to close sidebar -->
        <div id="sidebar-overlay" class="fixed inset-0 bg-black/50 z-10 hidden lg:hidden" aria-hidden="true"></div>

        <!-- Main Content Area -->
        <main class="flex-1 overflow-y-auto bg-terminal-bg relative w-full font-mono">
          <div class="absolute inset-0 terminal-scanline pointer-events-none z-10"></div>

          <div class="p-4 sm:p-6 min-h-full">
            <!-- Breadcrumb -->
            <div class="flex items-center gap-2 text-sm text-terminal-text-dim mb-4 sm:mb-6">
              <span class="flex items-center">
                <i class="i-ri-home-4-line w-4 h-4"></i>
              </span>
              <span>/</span>
              <span class="text-terminal-primary">{currentPath === "/" ? "home" : currentPath.slice(1)}</span>
              <span class="cursor-blink text-terminal-primary">_</span>
            </div>

            {
              showTitle && description && (
                <div class="mb-6 sm:mb-8">
                  <h1 class="text-xl sm:text-2xl font-bold text-terminal-text mb-2 flex items-center gap-3">
                    {description}
                  </h1>
                </div>
              )
            }
            <slot />
          </div>
        </main>
      </div>

      <!-- Terminal Footer -->
      <footer
        class="bg-terminal-bg-secondary border-t border-terminal-border px-3 sm:px-4 py-2 flex items-center justify-between text-[10px] sm:text-xs text-terminal-text-dim shrink-0">
        <div class="flex items-center gap-2 sm:gap-4">
          <span class="flex items-center gap-1">
            <span class="flex items-center">
              <i class="i-ri-keyboard-line w-3 h-3"></i>
            </span>
            <span class="hidden sm:inline" title="lol">NORMAL</span>
            <span class="sm:hidden" title="lol">NOR</span>
          </span>
          <span class="flex items-center gap-1">
            <span class="flex items-center">
              <i class="i-ri-file-code-line w-3 h-3"></i>
            </span>
            <span>UTF-8</span>
          </span>
          <a href="https://github.com/desertthunder/nvim" class="flex items-center gap-1 hover:text-terminal-success">
            <span class="flex items-center">
              <i class="i-simple-icons-neovim w-3 h-3"></i>
            </span>
            <span>CONF</span>
          </a>
          <a
            href="https://nix.desertthunder.dev"
            target="_blank"
            class="flex items-center gap-1 hover:text-terminal-secondary-bright">
            <span class="flex items-center">
              <i class="i-simple-icons-nixos w-3 h-3"></i>
            </span>
            <span>DOTFILES</span>
          </a>
        </div>
        <div class="flex items-center gap-1 sm:gap-2">
          <a href="/about" class="flex items-center gap-1 hover:text-terminal-primary transition-colors">
            <span class="flex items-center">
              <i class="i-ri-flashlight-line w-3 h-3"></i>
            </span>
            <span class="hidden sm:inline">built by Owais</span>
            <span class="sm:hidden">Owais</span>
          </a>
          <span class="hidden sm:inline">(est. 1993)</span>
        </div>
      </footer>
    </div>

    <script>
      function updateClock() {
        const clock = document.getElementById("clock");
        if (clock) {
          const now = new Date();
          const opts = { hour12: false, hour: "2-digit", minute: "2-digit", second: "2-digit" };
          clock.textContent = now.toLocaleTimeString("en-US", opts as Intl.DateTimeFormatOptions);
        }
      }
      updateClock();
      setInterval(updateClock, 1000);

      const menuToggle = document.getElementById("mobile-menu-toggle");
      const sidebar = document.getElementById("sidebar");
      const overlay = document.getElementById("sidebar-overlay");

      function toggleMenu() {
        const isExpanded = menuToggle?.getAttribute("aria-expanded") === "true";
        menuToggle?.setAttribute("aria-expanded", String(!isExpanded));
        sidebar?.classList.toggle("-translate-x-full");
        overlay?.classList.toggle("hidden");

        const icon = menuToggle?.querySelector("i");
        if (icon) {
          if (isExpanded) {
            icon.classList.remove("i-ri-close-line");
            icon.classList.add("i-ri-menu-line");
          } else {
            icon.classList.remove("i-ri-menu-line");
            icon.classList.add("i-ri-close-line");
          }
        }
      }

      function closeMenu() {
        menuToggle?.setAttribute("aria-expanded", "false");
        sidebar?.classList.add("-translate-x-full");
        overlay?.classList.add("hidden");

        const icon = menuToggle?.querySelector("i");
        if (icon) {
          icon.classList.remove("i-ri-close-line");
          icon.classList.add("i-ri-menu-line");
        }
      }

      menuToggle?.addEventListener("click", toggleMenu);
      overlay?.addEventListener("click", closeMenu);

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") {
          closeMenu();
        }
      });

      sidebar?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => {
          if (window.innerWidth < 1024) {
            closeMenu();
          }
        });
      });

      document.addEventListener("keydown", (e) => {
        if (e.key === "/" && !["INPUT", "TEXTAREA", "SELECT"].includes((e.target as HTMLElement)?.tagName)) {
          if (window.location.pathname.startsWith("/search")) return;
          e.preventDefault();
          window.location.href = "/search";
        }
      });
    </script>
  </body>
</html>
