---
import { getCollection } from "astro:content";
import TerminalLayout from "$/components/TerminalLayout.astro";
import { getLastPlayedTrack } from "$/lib/lastfm";
import { Image } from "astro:assets";

const allPosts = await getCollection("blog");
const lastPlayedTrack = await getLastPlayedTrack("browais");
---

<TerminalLayout title="home" description="Owais Jamil" showTitle={false} currentPath="/">
  <section class="mb-8 sm:mb-12">
    <div class="border border-terminal-border rounded-lg p-4 sm:p-6 bg-terminal-bg-secondary">
      <div class="flex items-start gap-3 sm:gap-4 mb-4">
        <span class="flex items-center shrink-0">
          <i class="i-ri-user-3-line w-10 h-10 sm:w-12 sm:h-12 text-terminal-primary"></i>
        </span>
        <div class="min-w-0 flex-1 max-w-3/4 md:max-w-2/3 flex flex-col gap-2">
          <h2 class="text-lg sm:text-xl font-bold text-terminal-text mb-1">{"\u003e whoami"}</h2>
          <p class="text-terminal-text/70 text-lg sm:text-xl">Hello!</p>
          <p class="text-terminal-text/70 text-lg">I'm Owais, a software engineer based out of Austin, TX.</p>
          <p class="text-terminal-text/70 text-lg">Thanks for checking out my personal website & blog.</p>
          <p class="text-terminal-text/70 text-lg">
            Professionally I have a lot of experience building scalable web applications and systems. I have a deep
            passion for learning new technologies and sharing my knowledge through writing and open source.
          </p>
          <p class="text-terminal-text/70 text-lg"></p>
        </div>
      </div>

      <div class="flex flex-wrap gap-3 sm:gap-4 text-sm">
        <a
          href="https://github.com/desertthunder"
          class="flex items-center gap-2 text-terminal-primary terminal-link min-h-11 px-2 -ml-2 rounded hover:bg-terminal-bg-tertiary/50 transition-colors">
          <span class="flex items-center">
            <i class="i-ri-github-line w-4 h-4"></i>
          </span>
          <span>github</span>
        </a>

        <a
          href="https://bsky.app/profile/desertthunder.dev"
          class="flex items-center gap-2 text-terminal-primary terminal-link min-h-11 px-2 -ml-2 rounded hover:bg-terminal-bg-tertiary/50 transition-colors">
          <span class="flex items-center">
            <i class="i-ri-bluesky-line w-4 h-4"></i>
          </span>
          <span>bluesky</span>
        </a>

        <a
          href="mailto:me@desertthunder.dev"
          class="flex items-center gap-2 text-terminal-primary terminal-link min-h-11 px-2 -ml-2 rounded hover:bg-terminal-bg-tertiary/50 transition-colors">
          <span class="flex items-center">
            <i class="i-ri-mail-line w-4 h-4"></i>
          </span>
          <span>email</span>
        </a>
      </div>
    </div>
  </section>

  <section class="mb-8 sm:mb-12">
    <div class="text-terminal-text-muted text-sm mb-3 flex items-center gap-2">
      <span class="flex items-center">
        <i class="i-ri-dashboard-line w-4 h-4"></i>
      </span>
      <span>SYSTEM STATS</span>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4">
      <div class="border border-terminal-border rounded p-3 sm:p-4">
        <div class="text-terminal-text text-sm font-heading mb-1">Uptime</div>
        <div class="text-terminal-primary text-xl sm:text-2xl font-bold">7+ years</div>
        <div class="text-terminal-text-muted text-xs">Building software</div>
      </div>

      <div class="border border-terminal-border rounded p-3 sm:p-4">
        <div class="text-terminal-text text-sm font-chrome mb-1">Writing</div>
        <div class="text-terminal-secondary text-xl sm:text-2xl font-bold">{allPosts.length} Posts</div>
        <div class="text-terminal-text-muted text-xs">
          <a href="blog" class="inline-flex items-center gap-1 hover:underline terminal-link">
            <span>View all</span>
            <i class="i-ri-arrow-right-s-line w-4 h-4"></i>
          </a>
        </div>
      </div>

      <div class="border border-terminal-border rounded p-3 sm:p-4 sm:col-span-2 lg:col-span-1">
        <div class="text-terminal-text text-sm font-heading mb-1">Location</div>
        <div class="text-terminal-success text-xl sm:text-2xl font-bold">Austin, TX</div>
        <div class="text-terminal-text-muted text-xs">GMT-6 (US Central Time)</div>
      </div>
      <div class="border border-terminal-border rounded p-3 sm:p-4 sm:col-span-2 lg:col-span-1">
        <div class="text-terminal-text text-sm font-chrome mb-2 flex items-center gap-1.5">
          <i class="i-ri-music-2-line w-4 h-4"></i>
          <span>{lastPlayedTrack?.nowPlaying ? "Now Playing" : "Last Played"}</span>
        </div>
        {
          lastPlayedTrack ? (
            <a
              href={lastPlayedTrack.url}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-center gap-3 min-w-0 rounded -m-1 p-1 hover:bg-terminal-bg-tertiary/50 transition-colors">
              {lastPlayedTrack.imageUrl ? (
                <Image
                  src={lastPlayedTrack.imageUrl}
                  alt={`last played track: ${lastPlayedTrack.name} by ${lastPlayedTrack.artist}`}
                  class="w-10 h-10 rounded border border-terminal-border object-cover shrink-0"
                  loading="lazy"
                  width="40"
                  height="40"
                />
              ) : (
                <span class="w-10 h-10 rounded border border-terminal-border bg-terminal-bg-secondary flex items-center justify-center shrink-0">
                  <i class="i-ri-disc-line w-5 h-5 text-terminal-warning" />
                </span>
              )}
              <span class="min-w-0">
                <span class="block text-terminal-warning text-sm sm:text-base font-bold truncate group-hover:underline">
                  {lastPlayedTrack.name}
                </span>
                <span class="block text-terminal-text-muted text-xs truncate">{lastPlayedTrack.artist}</span>
              </span>
            </a>
          ) : (
            <>
              <div class="text-terminal-warning text-xl sm:text-2xl font-bold">—</div>
              <div class="text-terminal-text-muted text-xs">Last.fm unavailable</div>
            </>
          )
        }
      </div>
    </div>
  </section>
</TerminalLayout>
