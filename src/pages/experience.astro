---
import TerminalLayout from "../components/TerminalLayout.astro";
import experienceData from "../content/data/experience.json";

const { experience } = experienceData;
---

<TerminalLayout 
  title="work" 
  description="Professional experience and career history"
  currentPath="/experience">

  <!-- Timeline -->
  <div class="space-y-0">
    {experience.map((job, index) => (
      <div class="relative">
        <!-- Timeline connector -->
        {index !== experience.length - 1 && (
          <div class="absolute left-[11px] top-8 bottom-0 w-0.5 bg-terminal-border"></div>
        )}
        
        <div class="flex gap-4">
          <!-- Timeline dot -->
          <div class="relative z-10">
            <div class="w-6 h-6 rounded-full bg-terminal-bg-secondary border-2 border-terminal-primary flex items-center justify-center">
              <span class="flex items-center">
                <i class="i-ri-briefcase-line w-3 h-3 text-terminal-primary"></i>
              </span>
            </div>
          </div>
          
          <!-- Content -->
          <div class="flex-1 pb-8">
            <div class="border border-terminal-border rounded-lg p-5">
              <div class="flex flex-wrap items-start justify-between gap-2 mb-3">
                <div>
                  <div class="flex items-center gap-2">
                    <span class="font-bold text-terminal-text text-lg">{job.company}</span>
                    {index === 0 && (
                      <span class="text-xs bg-terminal-success/20 text-terminal-success px-2 py-0.5 rounded">current</span>
                    )}
                  </div>
                  <div class="text-terminal-primary">{job.role}</div>
                </div>
                
                <div class="text-right">
                  <div class="text-terminal-text-muted text-sm">{job.period}</div>
                  <div class="text-terminal-text-dim text-xs">{job.location}</div>
                </div>
              </div>
              
              <p class="text-terminal-text-muted text-sm mb-4">{job.description}</p>
              
              <!-- Highlights -->
              <div class="mb-4">
                <div class="text-terminal-text-dim text-xs mb-2">HIGHLIGHTS</div>
                <ul class="space-y-1">
                  {job.highlights.map((highlight) => (
                    <li class="text-sm text-terminal-text-muted flex items-start gap-2">
                      <span class="flex items-center mt-1.5">
                        <i class="i-ri-check-line w-3 h-3 text-terminal-success"></i>
                      </span>
                      <span>{highlight}</span>
                    </li>
                  ))}
                </ul>
              </div>
              
              <!-- Technologies -->
              <div class="flex flex-wrap gap-1">
                {job.technologies.map((tech) => (
                  <span class="text-xs text-terminal-secondary bg-terminal-secondary/10 px-2 py-1 rounded">{tech}</span>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- Summary Stats -->
  <div class="mt-8 pt-4 border-t border-terminal-border grid grid-cols-2 md:grid-cols-4 gap-4">
    <div class="text-center">
      <div class="text-2xl font-bold text-terminal-primary">{experience.length}</div>
      <div class="text-xs text-terminal-text-dim">Positions</div>
    </div>
    <div class="text-center">
      <div class="text-2xl font-bold text-terminal-secondary">8+</div>
      <div class="text-xs text-terminal-text-dim">Years</div>
    </div>
    <div class="text-center">
      <div class="text-2xl font-bold text-terminal-success">{[...new Set(experience.flatMap(e => e.technologies))].length}</div>
      <div class="text-xs text-terminal-text-dim">Technologies</div>
    </div>
    <div class="text-center">
      <div class="text-2xl font-bold text-terminal-warning">∞</div>
      <div class="text-xs text-terminal-text-dim">Coffee</div>
    </div>
  </div>

</TerminalLayout>
