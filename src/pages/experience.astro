---
import TerminalLayout from "$/components/TerminalLayout.astro";
import data from "$/content/data/experience.json";
---

<TerminalLayout title="work" description="Professional experience and career history" currentPath="/experience">
  <div class="space-y-0">
    {
      data.experience.map((job, index) => (
        <div class="relative">
          {index !== data.experience.length - 1 && (
            <div class="absolute left-2.75 sm:left-3.25 top-7 sm:top-8 bottom-0 w-0.5 bg-terminal-border" />
          )}

          <div class="flex gap-3 sm:gap-4">
            <div class="relative z-10 shrink-0">
              <div class="w-5 h-5 sm:w-6 sm:h-6 rounded-full bg-terminal-bg-secondary border-2 border-terminal-primary flex items-center justify-center">
                <span class="flex items-center">
                  <i class="i-ri-briefcase-line w-2.5 h-2.5 sm:w-3 sm:h-3 text-terminal-primary" />
                </span>
              </div>
            </div>

            <div class="flex-1 pb-6 sm:pb-8 min-w-0">
              <div class="border border-terminal-border rounded-lg p-4 sm:p-5">
                <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 sm:gap-4 mb-3">
                  <div class="min-w-0">
                    <div class="flex items-center gap-2 flex-wrap">
                      <span class="font-bold text-terminal-text text-base sm:text-lg truncate">{job.company}</span>
                      {index === 0 && (
                        <span class="text-[10px] sm:text-xs bg-terminal-success/20 text-terminal-success px-1.5 sm:px-2 py-0.5 rounded">
                          current
                        </span>
                      )}
                    </div>
                    <div class="text-terminal-primary text-sm">{job.role}</div>
                  </div>

                  <div class="text-left sm:text-right shrink-0">
                    <div class="text-terminal-text-muted text-xs sm:text-sm">{job.period}</div>
                    <div class="text-terminal-text-dim text-xs">{job.location}</div>
                  </div>
                </div>

                <p class="text-terminal-text-muted text-xs sm:text-sm mb-3 sm:mb-4">{job.description}</p>

                <div class="mb-3 sm:mb-4">
                  <div class="text-terminal-text-dim text-[10px] sm:text-xs mb-2 uppercase tracking-wider">
                    Highlights
                  </div>
                  <ul class="space-y-1">
                    {job.highlights.map((highlight) => (
                      <li class="text-xs sm:text-sm text-terminal-text-muted flex items-start gap-2">
                        <span class="flex items-center mt-1 shrink-0">
                          <i class="i-ri-check-line w-3 h-3 text-terminal-success" />
                        </span>
                        <span>{highlight}</span>
                      </li>
                    ))}
                  </ul>
                </div>

                <div class="flex flex-wrap gap-1">
                  {job.technologies.map((tech) => (
                    <span class="text-[10px] sm:text-xs text-terminal-secondary bg-terminal-secondary/10 px-1.5 sm:px-2 py-0.5 sm:py-1 rounded">
                      {tech}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      ))
    }
  </div>

  <div class="mt-6 sm:mt-8 pt-4 border-t border-terminal-border grid grid-cols-3 gap-2 sm:gap-4">
    <div class="text-center">
      <div class="text-xl sm:text-2xl font-bold text-terminal-primary">{data.experience.length}</div>
      <div class="text-[10px] sm:text-xs text-terminal-text-dim">Positions</div>
    </div>
    <div class="text-center">
      <div class="text-xl sm:text-2xl font-bold text-terminal-secondary">7+</div>
      <div class="text-[10px] sm:text-xs text-terminal-text-dim">Years</div>
    </div>
    <div class="text-center">
      <div class="text-xl sm:text-2xl font-bold text-terminal-success">
        {[...new Set(data.experience.flatMap((e) => e.technologies))].length}
      </div>
      <div class="text-[10px] sm:text-xs text-terminal-text-dim">Technologies</div>
    </div>
  </div>
</TerminalLayout>
