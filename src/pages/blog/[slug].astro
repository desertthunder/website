---
import { getCollection, type CollectionEntry } from "astro:content";
import TerminalLayout from "../../components/TerminalLayout.astro";
import { transformLeafletToMarkdown } from "../../lib/leaflet-transform";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

type Props = { post: CollectionEntry<"blog"> };

const { post } = Astro.props;

const doc = JSON.parse(post.body || "{}");

const contentHtml = await transformLeafletToMarkdown(doc, post.data.atUri);
---

<TerminalLayout
  title={post.data.title}
  description={post.data.description || ""}
  currentPath={`/blog/${post.id}`}
  showTitle={false}>
  <div class="border-b border-terminal-border pb-6 mb-8">
    <div class="flex items-center gap-2 text-terminal-text-dim text-sm mb-4">
      <a href="/blog" class="terminal-link">blog</a>
      <span>/</span>
      <span>{post.id}</span>
    </div>

    <h1 class="text-3xl font-bold text-terminal-text mb-4">{post.data.title}</h1>

    <div class="flex flex-wrap items-center gap-4 text-sm text-terminal-text-muted">
      <span class="flex items-center gap-2">
        <span class="flex items-center">
          <i class="i-ri-calendar-line w-4 h-4"></i>
        </span>
        <time>
          {post.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
        </time>
      </span>

      <span class="flex items-center gap-2">
        <span class="flex items-center">
          <i class="i-ri-user-line w-4 h-4"></i>
        </span>
        <span>desertthunder.dev</span>
      </span>
    </div>
  </div>

  <article class="leaflet-content prose prose-invert max-w-none" set:html={contentHtml} />

  <div class="mt-12 pt-6 border-t border-terminal-border">
    <div class="flex items-center justify-between">
      <a href="/blog" class="text-terminal-primary terminal-link flex items-center gap-2">
        <span class="flex items-center">
          <i class="i-ri-arrow-left-line w-4 h-4"></i>
        </span>
        <span>back to blog</span>
      </a>

      <div class="flex items-center gap-4">
        <a
          href={`https://bsky.app/profile/desertthunder.dev/post/${post.data.leafletRkey}`}
          target="_blank"
          rel="noopener noreferrer"
          class="text-terminal-primary terminal-link flex items-center gap-2">
          <span class="flex items-center">
            <i class="i-ri-bluesky-line w-4 h-4"></i>
          </span>
          <span>view on bluesky</span>
        </a>
      </div>
    </div>
  </div>
</TerminalLayout>

<style>
  @reference "../../styles/styles.css";

  /* Style Leaflet-generated content with parent selectors */
  .leaflet-content {
    @apply text-terminal-text;
  }

  .leaflet-content :global(h1) {
    @apply text-3xl font-bold text-terminal-text mt-8 mb-4 border-b border-terminal-border pb-2;
  }

  .leaflet-content :global(h2) {
    @apply text-2xl font-bold text-terminal-text mt-8 mb-4 border-b border-terminal-border pb-2;
  }

  .leaflet-content :global(h3) {
    @apply text-xl font-bold text-terminal-text mt-6 mb-3;
  }

  .leaflet-content :global(h4) {
    @apply text-lg font-bold text-terminal-text mt-6 mb-3;
  }

  .leaflet-content :global(h5) {
    @apply text-base font-bold text-terminal-text mt-4 mb-2;
  }

  .leaflet-content :global(h6) {
    @apply text-sm font-bold text-terminal-text mt-4 mb-2;
  }

  .leaflet-content :global(p) {
    @apply text-terminal-text-muted mb-4 leading-relaxed;
  }

  .leaflet-content :global(ul) {
    @apply list-disc list-inside text-terminal-text-muted mb-4 ml-2;
  }

  .leaflet-content :global(ol) {
    @apply list-decimal list-inside text-terminal-text-muted mb-4 ml-2;
  }

  .leaflet-content :global(li) {
    @apply mb-1;
  }

  .leaflet-content :global(code) {
    @apply bg-terminal-bg-tertiary text-terminal-primary px-1.5 py-0.5 rounded text-sm;
  }

  .leaflet-content :global(pre) {
    @apply bg-terminal-bg-secondary border border-terminal-border rounded-lg p-4 overflow-x-auto mb-6;
  }

  .leaflet-content :global(pre code) {
    @apply bg-transparent text-terminal-text p-0;
  }

  .leaflet-content :global(blockquote) {
    @apply border-l-4 border-terminal-primary pl-4 italic text-terminal-text-muted my-6;
  }

  .leaflet-content :global(a) {
    @apply text-terminal-primary;
  }

  .leaflet-content :global(a:hover) {
    text-shadow: 0 0 8px rgba(59, 130, 246, 0.5);
    color: var(--color-terminal-primary-bright);
  }

  .leaflet-content :global(hr) {
    @apply border-terminal-border my-8;
  }

  .leaflet-content :global(strong) {
    @apply text-terminal-text font-bold;
  }

  .leaflet-content :global(img) {
    @apply rounded-lg border border-terminal-border max-w-full my-6;
  }

  /* Bluesky embed cards */
  .leaflet-content :global(.bsky-embed-card) {
    @apply border border-terminal-border rounded-lg p-4 mb-6 bg-terminal-bg-secondary;
  }

  .leaflet-content :global(.bsky-embed-header) {
    @apply flex items-center gap-3 mb-3;
  }

  .leaflet-content :global(.bsky-avatar) {
    @apply w-10 h-10 rounded-full border border-terminal-border;
  }

  .leaflet-content :global(.bsky-icon) {
    @apply w-10 h-10 rounded-full bg-terminal-primary/10 flex items-center justify-center text-lg;
  }

  .leaflet-content :global(.bsky-author) {
    @apply flex flex-col;
  }

  .leaflet-content :global(.bsky-display-name) {
    @apply font-bold text-terminal-text;
  }

  .leaflet-content :global(.bsky-handle) {
    @apply text-terminal-text-dim text-xs;
  }

  .leaflet-content :global(.bsky-label) {
    @apply font-bold text-terminal-text;
  }

  .leaflet-content :global(.bsky-content) {
    @apply text-terminal-text-muted mb-3;
  }

  .leaflet-content :global(.bsky-link) {
    @apply text-terminal-primary text-sm terminal-link inline-block;
  }

  /* Website embed cards */
  .leaflet-content :global(.website-embed-card) {
    @apply border border-terminal-border rounded-lg overflow-hidden mb-6 bg-terminal-bg-secondary;
  }

  .leaflet-content :global(.website-embed-link) {
    @apply flex flex-col no-underline text-inherit;
  }

  .leaflet-content :global(.website-embed-link:hover) {
    text-shadow: none;
  }

  .leaflet-content :global(.website-embed-card:hover) {
    @apply border-terminal-primary;
  }

  .leaflet-content :global(.website-embed-thumb) {
    @apply w-full h-40 object-cover border-0 rounded-none my-0;
  }

  .leaflet-content :global(.website-embed-info) {
    @apply flex flex-col gap-1 p-4;
  }

  .leaflet-content :global(.website-embed-title) {
    @apply font-bold text-terminal-text text-sm;
  }

  .leaflet-content :global(.website-embed-desc) {
    @apply text-terminal-text-muted text-xs line-clamp-2;
  }

  .leaflet-content :global(.website-embed-url) {
    @apply text-terminal-text-dim text-xs truncate;
  }

  /* Button blocks */
  .leaflet-content :global(.leaflet-button) {
    @apply inline-block px-4 py-2 border border-terminal-primary text-terminal-primary rounded text-sm font-mono mb-4;
  }

  .leaflet-content :global(.leaflet-button:hover) {
    @apply bg-terminal-primary/10;
    text-shadow: 0 0 8px rgba(59, 130, 246, 0.5);
  }

  /* Iframe link fallback */
  .leaflet-content :global(.leaflet-iframe-link) {
    @apply text-terminal-primary text-sm terminal-link inline-block mb-4;
  }

  /* Highlight (mark) styling */
  .leaflet-content :global(mark) {
    @apply bg-terminal-primary/20 text-terminal-text px-0.5 rounded;
  }

  /* Underline styling */
  .leaflet-content :global(u) {
    @apply underline decoration-terminal-primary/50;
  }

  /* Strikethrough styling */
  .leaflet-content :global(del) {
    @apply text-terminal-text-dim;
  }
</style>
