---
import type { GetStaticPaths, Page } from "astro";
import Base from "$layouts/Base.astro";
import CollapsibleBlogPost from "$components/CollapsibleBlogPost.astro";
import Paginator from "$components/Paginator.astro";
import { loadHybridBlog } from "$lib/content-loader";
import type { HybridPost } from "$lib/content-loader";

export const getStaticPaths = (async () => {
  const posts = await loadHybridBlog("desertthunder.dev");
  const pageSize = 10;
  const totalPages = Math.ceil(posts.length / pageSize);

  const allTagMap = new Map<string, number>();
  for (const post of posts) {
    post.tags.forEach((tag) => {
      allTagMap.set(tag, (allTagMap.get(tag) || 0) + 1);
    });
  }
  const allTags = Array.from(allTagMap.entries()).sort((a, b) => b[1] - a[1]);

  const paths: { params: { page: string }; props: { page: Page<HybridPost>; allTags: [string, number][] } }[] = [];

  for (let i = 1; i <= totalPages; i++) {
    const start = (i - 1) * pageSize;
    const end = Math.min(start + pageSize - 1, posts.length - 1);
    const data = posts.slice(start, start + pageSize);

    const page: Page<HybridPost> = {
      data,
      start,
      end,
      size: pageSize,
      total: posts.length,
      currentPage: i,
      lastPage: totalPages,
      url: {
        current: `/blog/p/${i}`,
        prev: i === 2 ? "/blog" : i > 2 ? `/blog/p/${i - 1}` : undefined,
        next: i < totalPages ? `/blog/p/${i + 1}` : undefined,
        first: "/blog",
        last: totalPages > 1 ? `/blog/p/${totalPages}` : "/blog",
      },
    };

    paths.push({
      params: { page: i.toString() },
      props: { page, allTags },
    });
  }

  return paths;
}) satisfies GetStaticPaths;

type Props = { page: Page<HybridPost>; allTags: [string, number][] };

const { page } = Astro.props;
const { allTags } = Astro.props;

const currentTagMap = new Map<string, number>();

for (const post of page.data) {
  post.tags.forEach((tag: string) => {
    currentTagMap.set(tag, (currentTagMap.get(tag) || 0) + 1);
  });
}
const currentTags = Array.from(currentTagMap.entries()).sort((a, b) => b[1] - a[1]);
---

<Base title="Blog — Owais Jamil" ogImage="/og/page/home.png">
  <section>
    <h2 class="text-3xl md:text-4xl text-cyan mb-8">Blog Posts</h2>
    {
      page.data.map((post) => (
        <CollapsibleBlogPost
          slug={post.slug}
          title={post.title}
          description={post.description}
          date={post.date}
          tags={post.tags}
          source={post.source}
          atUri={post.atUri}
        />
      ))
    }

    {
      (currentTags.length > 0 || allTags.length > 0) && (
        <div class="py-8">
          {currentTags.length > 0 && (
            <div class="mb-6">
              <span class="text-muted font-medium font-serif block mb-3">Current Tags</span>
              <div class="flex flex-wrap gap-2">
                {currentTags.map(([tag, count]) => (
                  <a href={`/tags/${tag}`} class="tag">
                    {tag} ({count})
                  </a>
                ))}
              </div>
            </div>
          )}

          {allTags.length > 0 && (
            <div class="mb-6">
              <span class="text-muted font-medium font-serif block mb-3">All Tags</span>
              <div class="flex flex-wrap gap-2">
                {allTags.map(([tag, count]) => (
                  <a href={`/tags/${tag}`} class="tag">
                    {tag} ({count})
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      )
    }
  </section>

  <Paginator page={page} label="Blog Pagination" />
</Base>

<script>
  import { setupPaginationNavigation } from "$utils/pagination";

  setupPaginationNavigation();
</script>
