---
import { getCollection, type CollectionEntry } from 'astro:content';
import TerminalLayout from "../../components/TerminalLayout.astro";

// Get all posts sorted by date
const allPosts = await getCollection('blog');
const posts: CollectionEntry<'blog'>[] = allPosts.sort((a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) => 
  b.data.date.getTime() - a.data.date.getTime()
);

// Get unique tags
const allTags = [...new Set(posts.flatMap((post: CollectionEntry<'blog'>) => post.data.tags))];
---

<TerminalLayout 
  title="blog" 
  description="Thoughts on software engineering, terminals, and developer experience"
  currentPath="/blog">

  <!-- Tags Filter -->
  <div class="mb-8">
    <div class="text-terminal-text-muted text-sm mb-3 flex items-center gap-2">
      <span class="flex items-center">
        <i class="i-ri-price-tag-3-line w-4 h-4"></i>
      </span>
      <span>TAGS</span>
    </div>
    <div class="flex flex-wrap gap-2">
      {allTags.map((tag: string) => (
        <span class="text-xs text-terminal-primary bg-terminal-primary/10 px-3 py-1.5 rounded-full cursor-pointer hover:bg-terminal-primary/20 transition-colors">
          #{tag}
        </span>
      ))}
    </div>
  </div>

  <!-- Posts List -->
  <div class="space-y-4">
    {posts.map((post: CollectionEntry<'blog'>, index: number) => (
      <article class="border border-terminal-border rounded-lg overflow-hidden hover:border-terminal-primary transition-colors">
        <div class="p-5">
          <div class="flex items-start justify-between gap-4 mb-3">
            <div class="flex items-center gap-3">
              <span class="text-terminal-text-dim font-mono text-sm">
                {String(index + 1).padStart(2, '0')}
              </span>
              <a href={`/blog/${post.id}`} class="text-lg font-bold text-terminal-text terminal-link">
                {post.data.title}
              </a>
            </div>
            <time class="text-terminal-text-dim text-xs whitespace-nowrap">
              {post.data.date.toLocaleDateString('en-US', { 
                year: 'numeric',
                month: 'long', 
                day: 'numeric' 
              })}
            </time>
          </div>
          
          <p class="text-terminal-text-muted text-sm mb-4 ml-8">{post.data.summary}</p>
          
          <div class="flex items-center justify-between ml-8">
            <div class="flex gap-2">
              {post.data.tags.map((tag: string) => (
                <span class="text-xs text-terminal-text-dim bg-terminal-bg-tertiary px-2 py-1 rounded">{tag}</span>
              ))}
            </div>
            
            <a href={`/blog/${post.id}`} class="text-terminal-primary text-sm terminal-link flex items-center gap-1">
              <span>read more</span>
              <span class="flex items-center">
                <i class="i-ri-arrow-right-line w-4 h-4"></i>
              </span>
            </a>
          </div>
        </div>
      </article>
    ))}
  </div>

  <!-- Stats Footer -->
  <div class="mt-8 pt-4 border-t border-terminal-border flex items-center gap-6 text-sm text-terminal-text-dim">
    <span class="flex items-center gap-2">
      <span class="flex items-center">
        <i class="i-ri-file-text-line w-4 h-4"></i>
      </span>
      <span>{posts.length} posts</span>
    </span>
    <span class="flex items-center gap-2">
      <span class="flex items-center">
        <i class="i-ri-price-tag-3-line w-4 h-4"></i>
      </span>
      <span>{allTags.length} tags</span>
    </span>
  </div>

</TerminalLayout>
