---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import TerminalLayout from "../../components/TerminalLayout.astro";

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project: CollectionEntry<'projects'>) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

type Props = {
  project: CollectionEntry<'projects'>;
};

const { project } = Astro.props;
const { Content } = await render(project);

const statusColors: Record<string, string> = {
  'In Development': 'text-terminal-warning',
  'Active': 'text-terminal-success',
  'Completed': 'text-terminal-secondary',
  'Archived': 'text-terminal-text-dim',
};
---

<TerminalLayout
  title={project.data.title}
  description={project.data.description}
  currentPath={`/projects/${project.id}`}
  showTitle={false}
>

  <!-- Project Header -->
  <div class="border-b border-terminal-border pb-6 mb-8">
    <div class="flex items-center gap-2 text-terminal-text-dim text-sm mb-4">
      <a href="/projects" class="terminal-link">projects</a>
      <span>/</span>
      <span>{project.id}</span>
    </div>
    
    <div class="flex items-start justify-between gap-4 mb-4">
      <div>
        <h1 class="text-3xl font-bold text-terminal-text mb-2">{project.data.title}</h1>
        <div class="flex items-center gap-3 text-sm">
          <span class:list={["font-medium", statusColors[project.data.status]]}>{project.data.status}</span>
          {project.data.featured && (
            <span class="flex items-center text-terminal-warning">
              <span class="flex items-center">
                <i class="i-ri-star-fill w-3 h-3 mr-1"></i>
              </span>
              featured
            </span>
          )}
        </div>
      </div>
      
      <div class="flex items-center gap-2">
        <a 
          href={project.data.repo} 
          target="_blank" 
          rel="noopener noreferrer"
          class="text-terminal-primary terminal-link flex items-center gap-1 text-sm"
        >
          <span class="flex items-center">
            <i class="i-ri-github-line w-4 h-4"></i>
          </span>
          <span>repo</span>
        </a>
        
        {project.data.link && (
          <a 
            href={project.data.link} 
            target="_blank" 
            rel="noopener noreferrer"
            class="text-terminal-primary terminal-link flex items-center gap-1 text-sm"
          >
            <span class="flex items-center">
              <i class="i-ri-external-link-line w-4 h-4"></i>
            </span>
            <span>demo</span>
          </a>
        )}
      </div>
    </div>
    
    <p class="text-terminal-text-muted mb-4">{project.data.description}</p>
    
    <div class="flex flex-wrap gap-2">
      {project.data.tech.map((tech: string) => (
        <span class="text-xs text-terminal-secondary bg-terminal-secondary/10 px-2 py-1 rounded">{tech}</span>
      ))}
      {project.data.tags.map((tag: string) => (
        <span class="text-xs text-terminal-primary bg-terminal-primary/10 px-2 py-1 rounded">#{tag}</span>
      ))}
    </div>
  </div>

  <!-- Project Content -->
  <article class="prose prose-invert prose-terminal max-w-none">
    <Content />
  </article>

  <!-- Project Footer -->
  <div class="mt-12 pt-6 border-t border-terminal-border">
    <div class="flex items-center justify-between">
      <a href="/projects" class="text-terminal-primary terminal-link flex items-center gap-2">
        <span class="flex items-center">
          <i class="i-ri-arrow-left-line w-4 h-4"></i>
        </span>
        <span>back to projects</span>
      </a>
      
      <div class="flex items-center gap-4">
        <a 
          href={project.data.repo} 
          target="_blank" 
          rel="noopener noreferrer"
          class="text-terminal-primary terminal-link flex items-center gap-2"
        >
          <span class="flex items-center">
            <i class="i-ri-github-line w-4 h-4"></i>
          </span>
          <span>view source</span>
        </a>
      </div>
    </div>
  </div>

</TerminalLayout>

<style>
  @reference "../../styles/styles.css";

  .prose-terminal {
    @apply text-terminal-text;
  }
  
  .prose-terminal h2 {
    @apply text-xl font-bold text-terminal-text mt-8 mb-4 border-b border-terminal-border pb-2;
  }
  
  .prose-terminal h3 {
    @apply text-lg font-bold text-terminal-text mt-6 mb-3;
  }
  
  .prose-terminal p {
    @apply text-terminal-text-muted mb-4 leading-relaxed;
  }
  
  .prose-terminal ul {
    @apply list-disc list-inside text-terminal-text-muted mb-4 ml-2;
  }
  
  .prose-terminal ol {
    @apply list-decimal list-inside text-terminal-text-muted mb-4 ml-2;
  }
  
  .prose-terminal li {
    @apply mb-1;
  }
  
  .prose-terminal code {
    @apply bg-terminal-bg-tertiary text-terminal-primary px-1.5 py-0.5 rounded text-sm;
  }
  
  .prose-terminal pre {
    @apply bg-terminal-bg-secondary border border-terminal-border rounded-lg p-4 overflow-x-auto mb-6;
  }
  
  .prose-terminal pre code {
    @apply bg-transparent text-terminal-text p-0;
  }
  
  .prose-terminal blockquote {
    @apply border-l-4 border-terminal-primary pl-4 italic text-terminal-text-muted my-6;
  }
  
  .prose-terminal a {
    @apply text-terminal-primary;
  }
  
  .prose-terminal a:hover {
    text-shadow: 0 0 8px rgba(59, 130, 246, 0.5);
    color: #60a5fa;
  }
  
  .prose-terminal hr {
    @apply border-terminal-border my-8;
  }
  
  .prose-terminal strong {
    @apply text-terminal-text font-bold;
  }
</style>
