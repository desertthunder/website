---
import { getCollection, render, type CollectionEntry } from "astro:content";
import TerminalLayout from "../../components/TerminalLayout.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project: CollectionEntry<"projects">) => ({ params: { slug: project.id }, props: { project } }));
}

type Props = { project: CollectionEntry<"projects"> };

const { project } = Astro.props;
const { Content } = await render(project);

const statusColors: Record<string, string> = {
  "In Development": "text-terminal-warning",
  Active: "text-terminal-success",
  Completed: "text-terminal-secondary",
  Archived: "text-terminal-text-dim",
};
---

<TerminalLayout
  title={project.data.title}
  description={project.data.description}
  currentPath={`/projects/${project.id}`}
  showTitle={false}>
  <div class="border-b border-terminal-border pb-4 sm:pb-6 mb-6 sm:mb-8">
    <div class="flex items-center gap-2 text-terminal-text-dim text-xs sm:text-sm mb-3 sm:mb-4">
      <a href="/projects" class="terminal-link">projects</a>
      <span>/</span>
      <span class="truncate">{project.id}</span>
    </div>

    <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3 sm:gap-4 mb-3 sm:mb-4">
      <div class="min-w-0">
        <h1 class="text-xl sm:text-2xl lg:text-3xl font-bold text-terminal-text mb-2">{project.data.title}</h1>
        <div class="flex items-center gap-3 text-xs sm:text-sm">
          <span class:list={["font-medium", statusColors[project.data.status]]}>{project.data.status}</span>
          {
            project.data.featured && (
              <span class="flex items-center text-terminal-warning">
                <span class="flex items-center">
                  <i class="i-ri-star-fill w-3 h-3 mr-1" />
                </span>
                <span>featured</span>
              </span>
            )
          }
        </div>
      </div>

      <div class="flex items-center gap-2">
        <a
          href={project.data.repo}
          target="_blank"
          rel="noopener noreferrer"
          class="text-terminal-primary terminal-link flex items-center gap-1 text-xs sm:text-sm min-h-11 px-2 -ml-2 rounded hover:bg-terminal-bg-tertiary/50 transition-colors">
          <span class="flex items-center">
            <i class="i-ri-github-line w-3.5 h-3.5 sm:w-4 sm:h-4"></i>
          </span>
          <span>repo</span>
        </a>

        {
          project.data.link && (
            <a
              href={project.data.link}
              target="_blank"
              rel="noopener noreferrer"
              class="text-terminal-primary terminal-link flex items-center gap-1 text-xs sm:text-sm min-h-11 px-2 -ml-2 rounded hover:bg-terminal-bg-tertiary/50 transition-colors">
              <span class="flex items-center">
                <i class="i-ri-external-link-line w-3.5 h-3.5 sm:w-4 sm:h-4" />
              </span>
              <span>demo</span>
            </a>
          )
        }
      </div>
    </div>

    <p class="text-terminal-text-muted text-sm mb-3 sm:mb-4">{project.data.description}</p>

    <div class="flex flex-wrap gap-1.5 sm:gap-2">
      {
        project.data.tech.map((tech: string) => (
          <span class="text-[10px] sm:text-xs text-terminal-secondary bg-terminal-secondary/10 px-1.5 sm:px-2 py-0.5 sm:py-1 rounded">
            {tech}
          </span>
        ))
      }
      {
        project.data.tags.map((tag: string) => (
          <span class="text-[10px] sm:text-xs text-terminal-primary bg-terminal-primary/10 px-1.5 sm:px-2 py-0.5 sm:py-1 rounded">
            #{tag}
          </span>
        ))
      }
    </div>
  </div>

  <article class="prose prose-invert prose-terminal max-w-none text-sm sm:text-base">
    <Content />
  </article>

  <div class="mt-8 sm:mt-12 pt-4 sm:pt-6 border-t border-terminal-border">
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <a href="/projects" class="text-terminal-primary terminal-link flex items-center gap-2 min-h-11">
        <span class="flex items-center">
          <i class="i-ri-arrow-left-line w-4 h-4"></i>
        </span>
        <span>back to projects</span>
      </a>

      <div class="flex items-center gap-4">
        <a
          href={project.data.repo}
          target="_blank"
          rel="noopener noreferrer"
          class="text-terminal-primary terminal-link flex items-center gap-2 min-h-11">
          <span class="flex items-center">
            <i class="i-ri-github-line w-4 h-4"></i>
          </span>
          <span>view source</span>
        </a>
      </div>
    </div>
  </div>
</TerminalLayout>

<style>
  @reference "../../styles/styles.css";

  .prose-terminal {
    @apply text-terminal-text;
  }

  .prose-terminal h2 {
    @apply text-lg sm:text-xl font-bold text-terminal-text mt-6 sm:mt-8 mb-3 sm:mb-4 border-b border-terminal-border pb-2;
  }

  .prose-terminal h3 {
    @apply text-base sm:text-lg font-bold text-terminal-text mt-4 sm:mt-6 mb-2 sm:mb-3;
  }

  .prose-terminal p {
    @apply text-terminal-text-muted mb-3 sm:mb-4 leading-relaxed;
  }

  .prose-terminal ul {
    @apply list-disc list-inside text-terminal-text-muted mb-3 sm:mb-4 ml-2;
  }

  .prose-terminal ol {
    @apply list-decimal list-inside text-terminal-text-muted mb-3 sm:mb-4 ml-2;
  }

  .prose-terminal li {
    @apply mb-1;
  }

  .prose-terminal code {
    @apply bg-terminal-bg-tertiary text-terminal-primary px-1 sm:px-1.5 py-0.5 rounded text-xs sm:text-sm;
  }

  .prose-terminal pre {
    @apply bg-terminal-bg-secondary border border-terminal-border rounded-lg p-3 sm:p-4 overflow-x-auto mb-4 sm:mb-6;
  }

  .prose-terminal pre code {
    @apply bg-transparent text-terminal-text p-0;
  }

  .prose-terminal blockquote {
    @apply border-l-4 border-terminal-primary pl-3 sm:pl-4 italic text-terminal-text-muted my-4 sm:my-6;
  }

  .prose-terminal a {
    @apply text-terminal-primary;
  }

  .prose-terminal a:hover {
    text-shadow: 0 0 8px rgba(59, 130, 246, 0.5);
    color: #60a5fa;
  }

  .prose-terminal hr {
    @apply border-terminal-border my-6 sm:my-8;
  }

  .prose-terminal strong {
    @apply text-terminal-text font-bold;
  }
</style>
