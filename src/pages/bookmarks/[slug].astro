---
import { getCollection, render, type CollectionEntry } from "astro:content";
import TerminalLayout from "$/components/TerminalLayout.astro";

export async function getStaticPaths() {
  const bookmarks = await getCollection("bookmarks");
  return bookmarks.map((bookmark: CollectionEntry<"bookmarks">) => ({
    params: { slug: bookmark.id },
    props: { bookmark },
  }));
}

type Props = { bookmark: CollectionEntry<"bookmarks"> };

const { bookmark } = Astro.props;
const { Content } = await render(bookmark);
---

<TerminalLayout
  title={bookmark.data.title}
  description={`Bookmarked on ${bookmark.data.date.toLocaleDateString()}`}
  currentPath={`/bookmarks/${bookmark.id}`}
  showTitle={false}>
  <div class="border-b border-terminal-border pb-4 sm:pb-6 mb-6 sm:mb-8">
    <div class="flex items-center gap-2 text-terminal-text-dim text-xs sm:text-sm mb-3 sm:mb-4">
      <a href="/bookmarks" class="terminal-link">bookmarks</a>
      <span>/</span>
      <span class="truncate">{bookmark.id}</span>
    </div>

    <h1 class="text-xl sm:text-2xl lg:text-3xl font-bold text-terminal-text mb-3 sm:mb-4">{bookmark.data.title}</h1>

    <div class="flex flex-wrap items-center gap-3 sm:gap-4 text-xs sm:text-sm text-terminal-text-muted">
      <a
        href={bookmark.data.url}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 text-terminal-primary terminal-link min-h-11 px-2 -ml-2 rounded hover:bg-terminal-bg-tertiary/50 transition-colors">
        <span class="flex items-center">
          <i class="i-ri-external-link-line w-3.5 h-3.5 sm:w-4 sm:h-4"></i>
        </span>
        <span class="truncate max-w-50 sm:max-w-md">{bookmark.data.url}</span>
      </a>
    </div>

    <div class="flex flex-wrap items-center gap-2 mt-3 sm:mt-4">
      <span class="text-[10px] sm:text-xs text-terminal-text-dim"
        >Bookmarked on {
          bookmark.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })
        }</span
      >
      {
        bookmark.data.tags.map((tag: string) => (
          <span class="text-[10px] sm:text-xs text-terminal-primary bg-terminal-primary/10 px-1.5 sm:px-2 py-0.5 sm:py-1 rounded">
            #{tag}
          </span>
        ))
      }
    </div>
  </div>

  <article class="prose prose-invert prose-terminal max-w-none text-sm sm:text-base">
    <Content />
  </article>

  <div class="mt-8 sm:mt-12 pt-4 sm:pt-6 border-t border-terminal-border">
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <a href="/bookmarks" class="text-terminal-primary terminal-link flex items-center gap-2 min-h-11">
        <span class="flex items-center">
          <i class="i-ri-arrow-left-line w-4 h-4"></i>
        </span>
        <span>back to bookmarks</span>
      </a>

      <div class="flex items-center gap-4">
        <a
          href={bookmark.data.url}
          target="_blank"
          rel="noopener noreferrer"
          class="text-terminal-primary terminal-link flex items-center gap-2 min-h-11">
          <span class="flex items-center">
            <i class="i-ri-external-link-line w-4 h-4"></i>
          </span>
          <span>visit site</span>
        </a>
      </div>
    </div>
  </div>
</TerminalLayout>
