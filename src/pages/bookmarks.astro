---
import { getCollection, render, type CollectionEntry } from "astro:content";
import TerminalLayout from "../components/TerminalLayout.astro";

const allBookmarks = await getCollection("bookmarks");
const bookmarksWithContent = await Promise.all(
  allBookmarks.map(async (bookmark) => {
    const { Content } = await render(bookmark);
    return { ...bookmark, Content };
  }),
);
const bookmarks = bookmarksWithContent.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const groupedBookmarks = bookmarks.reduce(
  (acc, bookmark) => {
    const cat = bookmark.data.category;
    if (!acc[cat]) {
      acc[cat] = [];
    }
    acc[cat].push(bookmark);
    return acc;
  },
  {} as Record<string, typeof bookmarks>,
);

const categories = Object.keys(groupedBookmarks).sort();

const uniqueCategories = [...new Set(bookmarks.map((b) => b.data.category))];

const categoryIcons: Record<string, string> = {
  learning: "i-ri-book-open-line",
  reference: "i-ri-file-list-3-line",
  tools: "i-ri-tools-line",
  community: "i-ri-team-line",
  education: "i-ri-graduation-cap-line",
  cli: "i-ri-terminal-line",
  shell: "i-ri-terminal-box-line",
  customization: "i-ri-palette-line",
  documentation: "i-ri-article-line",
  news: "i-ri-newspaper-line",
  macos: "i-ri-apple-line",
};
---

<TerminalLayout
  title="bookmarks"
  description="Curated collection of useful tools and resources"
  currentPath="/bookmarks">
  <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-6 mb-6 sm:mb-8 text-xs sm:text-sm text-terminal-text-dim">
    <span class="flex items-center gap-2">
      <span class="flex items-center">
        <i class="i-ri-bookmark-3-line w-4 h-4"></i>
      </span>
      <span>{bookmarks.length} bookmarks</span>
    </span>
    <span class="flex items-center gap-2">
      <span class="flex items-center">
        <i class="i-ri-folder-3-line w-4 h-4"></i>
      </span>
      <span>{uniqueCategories.length} categories</span>
    </span>
  </div>

  <div class="space-y-6 sm:space-y-8">
    {
      categories.map((category: string) => (
        <section>
          <div class="flex items-center gap-2 text-terminal-text-muted text-xs sm:text-sm mb-3 sm:mb-4 border-b border-terminal-border pb-2">
            <span class="flex items-center">
              <i class:list={[categoryIcons[category] || "i-ri-folder-3-line", "w-4", "h-4"]} />
            </span>
            <span class="uppercase tracking-wider">{category}</span>
            <span class="text-terminal-text-dim">({groupedBookmarks[category].length})</span>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-2 sm:gap-3">
            {groupedBookmarks[category].map((bookmark: any) => (
              <a
                href={`/bookmarks/${bookmark.id}`}
                class="group border border-terminal-border rounded p-3 sm:p-4 hover:border-terminal-primary transition-colors"
              >
                <div class="flex items-start gap-2 sm:gap-3">
                  <span class="flex items-center shrink-0">
                    <i class="i-ri-bookmark-line w-4 h-4 sm:w-5 sm:h-5 text-terminal-primary group-hover:text-terminal-primary-bright transition-colors" />
                  </span>

                  <div class="flex-1 min-w-0">
                    <div class="font-bold text-terminal-text text-sm truncate">{bookmark.data.title}</div>
                    <div class="text-terminal-text-muted text-xs sm:text-sm mt-1 line-clamp-2">
                      <bookmark.Content />
                    </div>
                  </div>

                  <span class="flex items-center shrink-0">
                    <i class="i-ri-arrow-right-line w-4 h-4 text-terminal-text-dim group-hover:text-terminal-primary transition-colors" />
                  </span>
                </div>
              </a>
            ))}
          </div>
        </section>
      ))
    }
  </div>

  <div class="mt-8 sm:mt-12 pt-4 border-t border-terminal-border text-center">
    <p class="text-terminal-text-muted text-xs sm:text-sm">
      Last updated: {new Date().toLocaleDateString("en-US", { month: "long", year: "numeric" })}
    </p>
    <p class="text-terminal-text-dim text-xs mt-2">
      Know a great tool?
      <a href="mailto:me@desertthunder.dev" class="text-terminal-primary terminal-link">Send a suggestion</a>
    </p>
  </div>
</TerminalLayout>
