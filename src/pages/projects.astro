---
import { getCollection, type CollectionEntry } from "astro:content";
import TerminalLayout from "$/components/TerminalLayout.astro";
import HighlightedProject from "$/components/HighlightedProject.astro";
import { IN_PROGRESS_STATUSES, PROJECT_STATUS_META } from "$/lib/projects/status";
import { getHighlightedProjectFrom } from "$/lib/projects/highlight";

const allProjects = await getCollection("projects");

const highlightedProject = getHighlightedProjectFrom(allProjects);
const projects: CollectionEntry<"projects">[] = [...allProjects]
  .filter((p: CollectionEntry<"projects">) => !p.data.highlighted)
  .sort((a: CollectionEntry<"projects">, b: CollectionEntry<"projects">) => {
    if (a.data.featured && !b.data.featured) return -1;
    if (!a.data.featured && b.data.featured) return 1;
    return b.data.date.getTime() - a.data.date.getTime();
  });
---

<TerminalLayout title="projects" description="Open source projects and developer tools" currentPath="/projects">
  <div class="grid grid-cols-3 gap-3 sm:gap-4 mb-6 sm:mb-8">
    <div class="border border-terminal-border rounded p-3 sm:p-4">
      <div class="text-terminal-text-dim text-[10px] sm:text-xs">Total</div>
      <div class="text-xl sm:text-2xl font-bold text-terminal-text">{allProjects.length}</div>
    </div>
    <div class="border border-terminal-border rounded p-3 sm:p-4">
      <div class="text-terminal-text-dim text-[10px] sm:text-xs">In progress</div>
      <div class="text-xl sm:text-2xl font-bold text-terminal-success">
        {allProjects.filter((p) => IN_PROGRESS_STATUSES.includes(p.data.status)).length}
      </div>
    </div>
    <div class="border border-terminal-border rounded p-3 sm:p-4">
      <div class="text-terminal-text-dim text-[10px] sm:text-xs">Featured</div>
      <div class="text-xl sm:text-2xl font-bold text-terminal-primary">
        {allProjects.filter((p) => p.data.featured).length}
      </div>
    </div>
  </div>

  {
    highlightedProject && (
      <div class="mb-4 sm:mb-6">
        <HighlightedProject project={highlightedProject} />
      </div>
    )
  }

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4">
    {
      projects.map((project) => (
        <a
          href={`/projects/${project.id}`}
          class="block border border-terminal-border rounded-lg p-4 sm:p-5 hover:border-terminal-primary hover:bg-terminal-primary/5 transition-colors">
          <div class="flex items-start justify-between mb-3">
            <div class="flex items-center gap-2 sm:gap-3 min-w-0 flex-1">
              <span class="flex items-center shrink-0">
                <i class="i-ri-folder-3-line w-5 h-5 sm:w-6 sm:h-6 text-terminal-primary" />
              </span>
              <div class="min-w-0">
                <div class="font-bold text-terminal-text text-sm sm:text-base truncate">{project.data.title}</div>
                <div
                  class:list={[
                    "flex items-center gap-1 text-[10px] sm:text-xs",
                    PROJECT_STATUS_META[project.data.status].color,
                  ]}>
                  <i class:list={[PROJECT_STATUS_META[project.data.status].icon, "w-2.5 h-2.5 sm:w-3 sm:h-3"]} />
                  <span>{PROJECT_STATUS_META[project.data.status].label}</span>
                </div>
              </div>
            </div>

            {project.data.featured && (
              <span class="flex items-center text-terminal-warning text-xs shrink-0 ml-2">
                <span class="flex items-center">
                  <i class="i-ri-star-fill w-3 h-3 mr-1" />
                </span>
                <span class="hidden sm:inline">featured</span>
              </span>
            )}
          </div>

          <p class="text-terminal-text-muted text-xs sm:text-sm mb-3 sm:mb-4 line-clamp-2">
            {project.data.description}
          </p>

          <div class="flex items-center gap-3 text-sm text-terminal-primary justify-end">
            <span class="flex items-center gap-1">
              <span>read more</span>
              <span class="flex items-center">
                <i class="i-ri-arrow-right-line w-4 h-4" />
              </span>
            </span>
          </div>
        </a>
      ))
    }
  </div>
</TerminalLayout>
