---
import TerminalLayout from "../components/TerminalLayout.astro";
---

<TerminalLayout title="search" description="Search all site content" currentPath="/search">
  <div class="space-y-6">
    <!-- Search input -->
    <div class="relative">
      <span class="absolute left-3 top-1/2 -translate-y-1/2 flex items-center pointer-events-none">
        <i class="i-ri-search-line w-4 h-4 text-terminal-text-dim"></i>
      </span>
      <input
        id="search-input"
        type="text"
        placeholder="grep -r '...' ~/site"
        autocomplete="off"
        class="w-full bg-terminal-bg-secondary border border-terminal-border rounded-lg pl-10 pr-4 py-2.5 text-sm text-terminal-text placeholder:text-terminal-text-dim focus:outline-none focus:border-terminal-primary font-mono"
      />
      <kbd
        id="search-shortcut"
        class="absolute right-3 top-1/2 -translate-y-1/2 text-[10px] text-terminal-text-dim border border-terminal-border rounded px-1.5 py-0.5 hidden sm:inline-block"
        >/</kbd
      >
    </div>

    <!-- Status line -->
    <div id="search-status" class="text-xs text-terminal-text-dim font-mono"></div>

    <!-- Results container -->
    <div id="search-results" class="space-y-3"></div>

    <!-- Empty state -->
    <div id="search-empty" class="hidden text-center py-12">
      <div class="text-terminal-text-dim text-sm">
        <span class="flex items-center justify-center mb-3">
          <i class="i-ri-file-search-line w-8 h-8 text-terminal-text-dim/50"></i>
        </span>
        <p>no matches found</p>
      </div>
    </div>

    <!-- Initial state -->
    <div id="search-initial" class="text-center py-12">
      <div class="text-terminal-text-dim text-sm">
        <span class="flex items-center justify-center mb-3">
          <i class="i-ri-terminal-line w-8 h-8 text-terminal-text-dim/50"></i>
        </span>
        <p>type to search across blog posts, projects, bookmarks, and experience</p>
      </div>
    </div>
  </div>
</TerminalLayout>

<script>
  import MiniSearch from "minisearch";

  const TYPE_LABELS: Record<string, { label: string; icon: string; color: string }> = {
    blog: { label: "blog", icon: "i-ri-article-line", color: "text-terminal-primary" },
    project: { label: "proj", icon: "i-ri-code-box-line", color: "text-terminal-success" },
    bookmark: { label: "link", icon: "i-ri-bookmark-line", color: "text-terminal-warning" },
    experience: { label: "work", icon: "i-ri-briefcase-line", color: "text-purple-400" },
  };

  type SearchEntry = {
    id: number;
    type: string;
    title: string;
    description: string;
    url: string;
    body: string;
    date?: string;
    tags?: string[];
  };

  const miniSearch = new MiniSearch<SearchEntry>({
    fields: ["title", "description", "body", "tagsText"],
    storeFields: ["type", "title", "description", "url", "body", "date", "tags"],
    searchOptions: { boost: { title: 10, description: 5, tagsText: 4, body: 1 }, prefix: true, fuzzy: 0.2 },
  });

  const input = document.getElementById("search-input") as HTMLInputElement;
  const resultsEl = document.getElementById("search-results")!;
  const statusEl = document.getElementById("search-status")!;
  const emptyEl = document.getElementById("search-empty")!;
  const initialEl = document.getElementById("search-initial")!;

  fetch("/search-index.json")
    .then((r) => r.json())
    .then((data: Omit<SearchEntry, "id">[]) => {
      const entries = data.map((entry, i) => ({ ...entry, id: i, tagsText: (entry.tags || []).join(" ") }));
      miniSearch.addAll(entries);

      const params = new URLSearchParams(window.location.search);
      const q = params.get("q");
      if (q) {
        input.value = q;
        runSearch(q);
      }
    });

  document.addEventListener("keydown", (e) => {
    if (e.key === "/" && document.activeElement !== input) {
      e.preventDefault();
      input.focus();
    }
    if (e.key === "Escape" && document.activeElement === input) {
      input.blur();
    }
  });

  let debounce: ReturnType<typeof setTimeout>;
  input.addEventListener("input", () => {
    clearTimeout(debounce);
    debounce = setTimeout(() => {
      const q = input.value.trim();
      const url = new URL(window.location.href);
      if (q) {
        url.searchParams.set("q", q);
      } else {
        url.searchParams.delete("q");
      }
      history.replaceState(null, "", url.toString());
      runSearch(q);
    }, 150);
  });

  function runSearch(query: string) {
    if (!query) {
      resultsEl.innerHTML = "";
      statusEl.textContent = "";
      emptyEl.classList.add("hidden");
      initialEl.classList.remove("hidden");
      return;
    }

    initialEl.classList.add("hidden");

    const results = miniSearch.search(query);
    const terms = query.toLowerCase().split(/\s+/).filter(Boolean);

    if (results.length === 0) {
      resultsEl.innerHTML = "";
      statusEl.textContent = `0 results for "${query}"`;
      emptyEl.classList.remove("hidden");
      return;
    }

    emptyEl.classList.add("hidden");
    statusEl.textContent = `${results.length} result${results.length !== 1 ? "s" : ""} for "${query}"`;

    resultsEl.innerHTML = results
      .slice(0, 30)
      .map((result) => {
        const entry = result as unknown as SearchEntry;
        const meta = TYPE_LABELS[entry.type] || TYPE_LABELS.blog;

        const snippet = buildSnippet(entry, terms);
        const highlightedTitle = highlight(escapeHtml(entry.title), terms);

        const dateStr = entry.date
          ? new Date(entry.date).toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })
          : "";

        const tagsHtml = (entry.tags || [])
          .slice(0, 3)
          .map(
            (t: string) =>
              `<span class="text-[10px] border border-terminal-border rounded px-1.5 py-0.5 text-terminal-text-dim">${escapeHtml(t)}</span>`,
          )
          .join("");

        return `<a href="${entry.url}" class="block border border-terminal-border rounded-lg p-4 hover:border-terminal-primary transition-colors group">
          <div class="flex items-start gap-3">
            <span class="flex items-center shrink-0 mt-0.5">
              <i class="${meta.icon} w-4 h-4 ${meta.color}"></i>
            </span>
            <div class="min-w-0 flex-1">
              <div class="flex items-start justify-between gap-3 mb-1">
                <div class="flex items-center gap-2 min-w-0">
                  <span class="text-[10px] font-mono ${meta.color} border border-current/30 rounded px-1 py-0.5 shrink-0 uppercase">${meta.label}</span>
                  <span class="text-sm font-bold text-terminal-text group-hover:text-terminal-primary-bright truncate">${highlightedTitle}</span>
                </div>
                ${dateStr ? `<span class="text-[10px] text-terminal-text-dim whitespace-nowrap shrink-0">${dateStr}</span>` : ""}
              </div>
              <div class="text-xs text-terminal-text-muted leading-relaxed line-clamp-2">${snippet}</div>
              ${tagsHtml ? `<div class="flex flex-wrap gap-1 mt-2">${tagsHtml}</div>` : ""}
            </div>
          </div>
        </a>`;
      })
      .join("");
  }

  function buildSnippet(entry: SearchEntry, terms: string[]): string {
    const source = entry.description || entry.body;
    if (!source) return "";

    const lower = source.toLowerCase();
    let bestIndex = -1;

    for (const term of terms) {
      const idx = lower.indexOf(term);
      if (idx !== -1 && (bestIndex === -1 || idx < bestIndex)) {
        bestIndex = idx;
      }
    }

    let snippet: string;
    if (bestIndex === -1) {
      snippet = source.slice(0, 160);
    } else {
      const start = Math.max(0, bestIndex - 60);
      const end = Math.min(source.length, bestIndex + 100);
      snippet = (start > 0 ? "..." : "") + source.slice(start, end) + (end < source.length ? "..." : "");
    }

    return highlight(escapeHtml(snippet), terms);
  }

  function highlight(text: string, terms: string[]): string {
    if (!terms.length) return text;
    const escaped = terms.map((t) => t.replace(/[.*+?^${}()|[\]\\]/g, "\\$&"));
    const re = new RegExp(`(${escaped.join("|")})`, "gi");
    return text.replace(re, '<mark class="bg-terminal-primary/25 text-terminal-text rounded px-0.5">$1</mark>');
  }

  function escapeHtml(s: string): string {
    return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
  }
</script>
